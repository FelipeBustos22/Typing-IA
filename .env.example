# ── Variables de entorno — copia este archivo como .env.local ────────────────
#
#   cp .env.example .env.local
#
# .env.local es ignorado por git (nunca se sube al repo).
# .env.example SÍ se sube: es la plantilla de referencia para otros desarrolladores.

# ── Ollama (desarrollo local) ─────────────────────────────────────────────────
# Ollama se usa automáticamente cuando GROQ_API_KEY no está definida.
# Requiere tener Ollama instalado y corriendo: https://ollama.com
OLLAMA_URL=http://127.0.0.1:11434/api/chat
OLLAMA_MODELO=phi4-mini:3.8b

# ── Groq (producción, opcional) ───────────────────────────────────────────────
# Si esta variable está definida, la app usa Groq en lugar de Ollama.
# Obtén tu API key en: https://console.groq.com
# En producción (Vercel), configúrala en Settings → Environment Variables.
# En local, descomenta esta línea y pega tu key:
# GROQ_API_KEY=
